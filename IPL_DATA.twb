      <column caption='Total Runs' datatype='integer' name='[Calculation_0590981242843136]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Runs])' />
      </column>
      <column caption='Total Matches' datatype='integer' name='[Calculation_0590981242933249]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Mat])' />
      </column>
      <column caption='Total Sixes' datatype='integer' name='[Calculation_0590981243043842]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([6s])' />
      </column>
      <column caption='Total Fours' datatype='integer' name='[Calculation_0590981243154435]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([4s])' />
      </column>
      <column caption='Total Wickets' datatype='integer' name='[Calculation_0590981243244548]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([B_Wkts])' />
      </column>
      <column caption='Strike Rate' datatype='real' name='[Calculation_0590981243367429]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Runs]) / SUM([BF]) * 100' />
      </column>
      <column caption='Economy Rate' datatype='real' name='[Calculation_0590981243441158]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([B_Runs]) / (SUM([B_Balls]) / 6)' />
      </column>
      <column caption='Total Centuries' datatype='integer' name='[Calculation_0590981243547655]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([100s])' />
      </column>
      <column caption='Total Half Centuries' datatype='integer' name='[Calculation_0590981243605000]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([50s])' />
      </column>
      <column caption='Total Ducks' datatype='integer' name='[Calculation_0590981243674633]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([0s])' />
      </column>
      <column caption='Batting Average' datatype='real' name='[Calculation_0590981243748362]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Runs]) / (SUM([Inns]) - SUM([NO]))' />
      </column>
      <column caption='Bowling Average' datatype='real' name='[Calculation_0590981243805707]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([B_Runs]) / SUM([B_Wkts])' />
      </column>
      <column caption='SOLD PRICE TEAM' datatype='real' name='[Calculation_0590981256421390]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF ISNULL([SOLD_PRICE]) OR STR([SOLD_PRICE]) = &quot;&quot; OR STR([SOLD_PRICE]) = &quot;Unsold&quot; THEN&#10;0&#10;ELSE&#10;FLOAT(&#10;REPLACE(&#10;REPLACE(&#10;REPLACE(&#10;REPLACE(STR([SOLD_PRICE]),&quot;₹&quot;,&quot;&quot;),&#10;&quot;cr&quot;,&quot;&quot;),&#10;&quot;Cr&quot;,&quot;&quot;),&#10;&quot;,&quot;,&quot;&quot;)&#10;)&#10;END' />
      </column>
      <column caption='Selected Metric' datatype='integer' name='[Calculation_0805661236551681]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [Parameters].[Parameter 1] = &quot;Batting&quot; THEN [Runs]&#10;ELSE [B_Wkts]&#10;END' />
      </column>
      <column caption='Overs  bowled' datatype='real' name='[Calculation_1085006528753664]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([B_Balls])/6' />
      </column>
      <column caption='B Economy' datatype='real' name='[Calculation_1085006529261569]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([B_Runs])/(SUM([B_Balls])/6)' />
      </column>
